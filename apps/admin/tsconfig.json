{
	"extends": "@workspace/typescript-config/nextjs.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./*"],
			"@workspace/ui/*": ["../../packages/ui/src/*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"strictNullChecks": true
	},
	"include": ["**/*.ts", "**/*.tsx", "next-env.d.ts", "next.config.js", ".next/types/**/*.ts", "../../packages/ui/src/Logout.tsx"],
	"exclude": ["node_modules"]
}
