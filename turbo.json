{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			],
			"env": [
				"NEXT_PUBLIC_SUPABASE_URL",
				"NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
				"SUPABASE_SECRET_KEY",
				"NEXT_PUBLIC_APP_URL",
				"NEXT_PUBLIC_SITE_URL",
				"NEXT_PUBLIC_RAZORPAY_KEY_ID",
				"RAZORPAY_KEY_SECRET",
				"RAZORPAY_WEBHOOK_SECRET"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}